}

### find activities by lead
GET http://{{ URL }}/api/leads/238/activities
Content-Type: application/json


### get lead by id
GET http://{{ URL }}/api/leads/238
Content-Type: application/json

### zoek contact persons
GET http://{{ URL }}/admin/contacts/persons/search
Content-Type: application/json

{
    "first_name": "John"
}

### get person info
GET https://{{ URL }}/api/keycloak/persons/39cdb90c-b41e-4126-b271-daafaa29f982
Accept: application/json
Content-Type: application/json
X-API-KEY: {{API_KEY}}

### get person info
GET https://{{ URL }}/api/patient/4e162dae-4ea9-4b66-ae67-9ff1fb3f57ed/documents
Accept: application/json
Content-Type: application/json
X-API-KEY: {{API_KEY}}

### get person info
GET https://{{ URL }}/api/patient/4e162dae-4ea9-4b66-ae67-9ff1fb3f57ed/notifications
Accept: application/json
Content-Type: application/json
X-API-KEY: {{API_KEY}}
