{
    "preset": "laravel",
    "style": "psr12",
    "exclude": [
        "packages/*",
        "docker/*",
        "bootstrap/*",
        "storage/*",
        "docs/*",
        "flows/*"
    ],
    "pint": {
        "preset": "laravel",
        "rules": {
            "concat_space": {
                "spacing": "one"
            },
            "no_unused_imports": true
        }
    }
}
